# FakeGuard Backend Environment Variables

# Server Configuration
PORT=3000

# MongoDB Connection
# Local: mongodb://localhost:27017/fakeguard
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/fakeguard
MONGODB_URI=mongodb://localhost:27017/fakeguard

# JWT Secret (change this in production!)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Node Environment
NODE_ENV=development
